{
  "name": "visual-prompt-kit",
  "version": "0.1.0",
  "description": "Generate visual prompts from parameter catalogs and render images through provider profiles.",
  "type": "module",
  "license": "MIT",
  "author": "El Hombre <elhombre.dev@gmail.com>",
  "keywords": [
    "prompt",
    "image-generation",
    "gemini",
    "openai",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "vpk": "./bin/vpk",
    "visual-prompt": "./bin/vpk"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "default": "./dist/providers/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "docs",
    "examples/**/*.md",
    "examples/**/*.jsonc",
    "examples/.env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "npm run build",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "dotenv": "^17.4.2",
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^5.9.3"
  }
}
